sort=-time
layer=overlay
background-color=#2e3440B3
width=300
height=130
border-size=1
border-color=#99c0d0
border-radius=12
icons=1
max-icon-size=50
default-timeout=5000
ignore-timeout=0
font="FiraCode Nerd Mono" 18
margin=10,30
padding=12,20
text-alignment=center
anchor=top-right

[urgency=low]
border-color=#cccccc

[urgency=normal]
border-color=#99c0d0

[urgency=critical]
border-color=#bf616a
default-timeout=0
