#!/usr/bin/sh
# @author nate zhou
# @since 2025

. "${HOME}/.cache/wal/colors.sh"
BAT="BAT0"
POWER="/sys/class/power_supply"

status="$(cat $POWER/$BAT/status)"
level="$(cat $POWER/$BAT/capacity)"
color="$color6"

case "$status" in
    "Discharging")
        case "$level" in
            [0-5]) icon="σΑ²é";;
            [6-9]) icon="σΑ¹Κ";;
            1[0-9]) icon="σΑ¹Μ";;
            2[0-9]) icon="σΑ¹Φ";;
            3[0-9]) icon="σΑ¹Ϋ";;
            4[0-9]) icon="σΑ¹Ϋ";;
            5[0-9]) icon="σΑ¹Ψ";;
            6[0-9]) icon="σΑ¹Ω";;
            7[0-9]) icon="σΑ²Ä";;
            8[0-9]) icon="σΑ²¹";;
            9[0-9]) icon="σΑ²²";;
            100)    icon="σΑ¹Ι";;
        esac
        ;;
    "Not charging")
        icon="ο΅Π"
        ;;
    "Charging")
        icon="σΑ²³"
        ;;
esac


# ` `(U+2009) is the Thin Space
echo "$icon"βÄâ" $level"%
echo
echo "$color"

case $BLOCK_BUTTON in
    3) notify-send -u low -r 3301 "$icon $(basename $0)" "$status $level%\n$(upower -i /org/freedesktop/UPower/devices/battery_$BAT | grep  'time to empty:' | sed -E 's/[ \t]+/ /g')"
        ;;
    1) pkill +SIGRTMIN+12 i3blocks &
        ;;
esac

