# Bar
include $HOME/.cache/wal/colors-sway

bar {
    status_command i3blocks
    position top
    separator_symbol " | "

    # When the status_command prints a new line to stdout, swaybar updates.
    # The default just shows the current date and time.
    # status_command while date +'%_I:%M'; do sleep 1; done

    colors {
    	font pango:Source Sans 3 Semibold 11
        focused_workspace  $color6 $color6 $background
        statusline #eeeeee
    	separator $color6
        background $backgroundE6
        # inactive_workspace $color680 $color680 #5c5c5c
        inactive_workspace $backgroundE6 $backgroundE6 $color6
	    # active_workspace #323232 #323232 #eeeeee
    }
}
